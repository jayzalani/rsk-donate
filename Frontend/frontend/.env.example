# ─── Required ─────────────────────────────────────────────────────────────────

# Address of the deployed DonationVault contract (single-vault dashboard)
NEXT_PUBLIC_CONTRACT_ADDRESS=your_contract_address_here

# Address of the deployed DonationVaultFactory contract (/deploy and /vaults pages)
# Deploy with: cd SmartContract/rootstock-hardhat-starterkit && npx hardhat deploy --tags DonationVaultFactory --network rskTestnet
NEXT_PUBLIC_FACTORY_ADDRESS=your_factory_address_here

# ─── Optional ──────────────────────────────────────────────────────────────────

# Rootstock RPC API key for the paid endpoint (https://dashboard.rootstock.io)
# If omitted, the public node is used automatically as a fallback.
NEXT_PUBLIC_RSK_API_KEY=your_rsk_api_key_here
